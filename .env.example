APP_NAME="Giricahyo Carbon API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── MySQL — sesuaikan dengan konfigurasi server kampus ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=giricahyo_carbon
DB_USERNAME=root
DB_PASSWORD=

# ── JWT (generate dengan: php artisan jwt:secret) ──
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# ── CORS — izinkan frontend React ──
FRONTEND_URL=http://localhost:5173

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
